{
  "name": "@binance-futures/bot-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build -w @binance-futures/shared && tsx watch src/main.ts",
    "build": "npm run build -w @binance-futures/shared && tsc -p tsconfig.json",
    "start": "npm run build -w @binance-futures/shared && tsc -p tsconfig.json && node dist/apps/bot-worker/src/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@binance-futures/shared": "0.1.0",
    "@prisma/client": "^6.19.0",
    "axios": "^1.14.0",
    "dotenv": "^17.3.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
